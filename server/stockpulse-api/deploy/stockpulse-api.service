[Unit]
Description=StockPulse FastAPI Backend
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/stockpulse-api
EnvironmentFile=/opt/stockpulse-api/.env
ExecStart=/opt/stockpulse-api/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8002 --workers 1
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
